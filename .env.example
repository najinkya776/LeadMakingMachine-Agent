# LeadMakingMachine Environment Configuration

# API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Apify (pre-configured with your token)
APIFY_TOKEN=your_apify_token_here

# Database
DB_HOST=your_db_host_here
DB_PORT=5432
DB_NAME=your_db_name_here
DB_USER=your_db_user_here
DB_PASSWORD=

# Redis
REDIS_HOST=your_redis_host_here
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Email (SMTP) - Hostinger
SMTP_HOST=your_smtp_host_here
SMTP_PORT=465
SMTP_USER=your_smtp_user_here
SMTP_PASSWORD=your_smtp_password_here
FROM_EMAIL=your_from_email_here

# Inbound Email Processing (IMAP)
IMAP_HOST=your_imap_host_here
IMAP_PORT=993
INBOUND_EMAIL=your_inbound_email_here
INBOUND_EMAIL_PASSWORD=your_inbound_email_password_here
EMAIL_POLL_INTERVAL=300

# Sales aliases (configure in Hostinger)
SALES_EMAIL=your_sales_email_here
HELLO_EMAIL=your_hello_email_here

# WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Payment (PayPal)
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_SANDBOX=false

PAYPAL_ME_LINK=your_paypal_me_link_here
PAYPAL_STARTER_LINK=your_paypal_starter_link_here
PAYPAL_PROFESSIONAL_LINK=your_paypal_professional_link_here
PAYPAL_PREMIUM_LINK=your_paypal_premium_link_here

# Build Integration
SITEBUILDER_URL=your_sitebuilder_url_here
SITEBUILDER_API_KEY=

# Optional
TELEGRAM_BOT_TOKEN=
WHATSAPP_META_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_META_PHONE_NUMBER_ID=your_phone_number_id
